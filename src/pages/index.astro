---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import { getCollection } from 'astro:content';
import { getProjects } from '@/lib/github';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featuredProjects = getProjects()
  .filter((p) => p.featured)
  .slice(0, 3);

const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <Hero />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <!-- Featured Projects -->
    {featuredProjects.length > 0 && (
      <section class="mb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-text-primary">Featured Projects</h2>
          <a
            href={`${base}projects`}
            class="text-sm text-accent hover:text-accent-hover transition-colors"
          >
            View All →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredProjects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-bg-secondary rounded-lg border border-border p-5 hover:shadow-md transition-all hover:-translate-y-0.5"
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-semibold text-text-primary group-hover:text-accent transition-colors">
                  {project.name}
                </h3>
                <span class="flex-shrink-0 ml-2 px-1.5 py-0.5 bg-accent/10 text-accent text-[10px] font-medium rounded">
                  Featured
                </span>
              </div>
              <p class="text-sm text-text-secondary mb-4 line-clamp-2">
                {project.customDescription || project.description || 'No description'}
              </p>
              <div class="flex items-center gap-3 text-xs text-text-muted">
                <span>⭐ {project.stars}</span>
                <span>🔄 {project.forks}</span>
                {project.language && <span>{project.language}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Latest Posts -->
    {recentPosts.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-text-primary">Latest Posts</h2>
          <a
            href={`${base}blog`}
            class="text-sm text-accent hover:text-accent-hover transition-colors"
          >
            View All →
          </a>
        </div>
        <div class="space-y-4">
          {recentPosts.map((post) => (
            <a
              href={`${base}blog/${post.id}`}
              class="block bg-bg-secondary rounded-lg border border-border p-5 hover:shadow-md transition-shadow"
            >
              <h3 class="font-semibold text-text-primary mb-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-text-secondary mb-3 line-clamp-2">
                {post.data.summary}
              </p>
              <div class="flex items-center gap-3 text-xs text-text-muted">
                <time>
                  {post.data.date.toLocaleDateString('zh-CN')}
                </time>
                <span>·</span>
                <span>{Math.max(1, Math.ceil((post.body?.length || 0) / 500))} min read</span>
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="px-1.5 py-0.5 bg-badge-bg text-badge-text rounded">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
